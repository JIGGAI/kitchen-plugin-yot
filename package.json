{
  "name": "@jiggai/kitchen-plugin-yot",
  "version": "0.1.5",
  "description": "You're On Time CRM plugin for ClawKitchen",
  "repository": {
    "type": "git",
    "url": "https://github.com/JIGGAI/kitchen-plugin-yot"
  },
  "homepage": "https://github.com/JIGGAI/kitchen-plugin-yot",
  "bugs": {
    "url": "https://github.com/JIGGAI/kitchen-plugin-yot/issues"
  },
  "main": "dist/index.js",
  "files": [
    "dist/",
    "db/migrations/",
    "README.md"
  ],
  "kitchenPlugin": {
    "id": "yot",
    "name": "You're On Time CRM",
    "teamTypes": [
      "marketing-team",
      "ops-team"
    ],
    "tabs": [
      {
        "id": "overview",
        "label": "Overview",
        "icon": "chart",
        "bundle": "./dist/tabs/overview.js"
      },
      {
        "id": "locations",
        "label": "Locations",
        "icon": "map-pin",
        "bundle": "./dist/tabs/locations.js"
      },
      {
        "id": "clients",
        "label": "Clients",
        "icon": "users",
        "bundle": "./dist/tabs/clients.js"
      },
      {
        "id": "stylists",
        "label": "Stylists",
        "icon": "scissors",
        "bundle": "./dist/tabs/stylists.js"
      },
      {
        "id": "services",
        "label": "Services",
        "icon": "list",
        "bundle": "./dist/tabs/services.js"
      },
      {
        "id": "appointments",
        "label": "Appointments",
        "icon": "calendar",
        "bundle": "./dist/tabs/appointments.js"
      },
      {
        "id": "sync-runs",
        "label": "Sync Runs",
        "icon": "clock",
        "bundle": "./dist/tabs/sync-runs.js"
      }
    ],
    "apiRoutes": "./dist/api/handler.js",
    "migrations": "./db/migrations"
  },
  "scripts": {
    "build": "node scripts/build.js",
    "typecheck": "tsc --noEmit",
    "test": "vitest run --passWithNoTests",
    "prepublishOnly": "npm run build"
  },
  "dependencies": {
    "better-sqlite3": "^11.0.0",
    "drizzle-orm": "^0.36.0"
  },
  "devDependencies": {
    "@types/better-sqlite3": "^7.6.0",
    "@types/node": "^20.0.0",
    "esbuild": "^0.24.0",
    "typescript": "^5.0.0",
    "vitest": "^2.0.0"
  }
}
